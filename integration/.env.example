# -----------------------------------------------------------------------------
# Integration smoke-test configuration.
#
# Copy to `.env` (which is git-ignored) and adjust as needed:
#     cp integration/.env.example integration/.env
#
# `docker compose`, the bootstrap scripts, and the SmokeTests app all read this
# file. Values that the bootstrap DISCOVERS at runtime (the VaultWarden personal
# API key, the Infisical machine-identity credentials and project id) are written
# back out to `integration/.env.generated` by the bootstrap step.
# -----------------------------------------------------------------------------

# ---- Ports the containers publish on localhost ------------------------------
VAULTWARDEN_PORT=8080
INFISICAL_PORT=8082
VAULT_PORT=8200

# ---- The account the bootstrap creates in VaultWarden -----------------------
BITWARDEN_EMAIL=smoke@example.com
BITWARDEN_MASTER_PASSWORD=SmokeTest-Master-Pw-123!
# KDF iterations for the new account. 600000 matches the Bitwarden default.
BITWARDEN_KDF_ITERATIONS=600000
# Where the provider (and bootstrap) reach VaultWarden. Host-side default below;
# inside the compose network the bootstrap uses http://vaultwarden.
BITWARDEN_SERVER_URL=http://localhost:8080

# ---- The admin account + machine identity the bootstrap creates in Infisical -
INFISICAL_ADMIN_EMAIL=admin@example.com
INFISICAL_ADMIN_PASSWORD=SmokeTest-Admin-Pw-123!
INFISICAL_PROJECT_NAME=smoke-tests
INFISICAL_ENVIRONMENT=dev
INFISICAL_SITE_URL=http://localhost:8082
# Optional folder within the environment; leave as / for the root.
INFISICAL_SECRET_PATH=/

# ---- HashiCorp Vault (dev mode) ---------------------------------------------
# The dev-server root token; also injected into the container as the root token,
# so the two always match. The adapter authenticates with it (token auth).
VAULT_TOKEN=smoke-root-token
# Host-facing address the SmokeTests app uses (the bootstrap uses http://vault:8200).
VAULT_ADDR=http://localhost:8200
# KV v2 mount (dev server mounts KV v2 at "secret/") and an optional path prefix.
VAULT_MOUNT=secret
VAULT_BASE_PATH=smoke
# The field each KV item stores the value under.
VAULT_VALUE_KEY=value

# ---- Seed data ---------------------------------------------------------------
# The { key: value } pairs the bootstrap writes into BOTH systems and the
# SmokeTests app then verifies live in `seed.json` (kept out of .env because JSON
# in a dotenv/compose env_file quotes badly). Edit seed.json to change them; keep
# the three key suffixes -login-secret / -note-secret / -field-secret so the
# VaultWarden seed exercises all three adapter value-resolution paths.

# ---- Optional -----------------------------------------------------------------
# Allow the Infisical block to exercise Set/Get/Delete against the live instance.
ALLOW_MUTATING_TESTS=true
